    <string name="triggers_pending_service">%1$d Service</string>
    <string name="triggers_pending_broadcast">%1$d Broadcast</string>
    <string name="triggers_pending_explanation">The app holds registered PendingIntents. The system or other apps can activate them at any moment — via a notification, AlarmManager, or a system event — which will start the process.</string>

    <!-- Boot Receivers -->
    <string name="triggers_boot_detail_normal">BOOT_COMPLETED</string>
    <string name="triggers_boot_detail_locked">LOCKED_BOOT_COMPLETED</string>
    <string name="triggers_boot_detail_both">BOOT_COMPLETED + LOCKED_BOOT_COMPLETED</string>
    <string name="triggers_boot_explanation_normal">The app starts on every device boot via a BOOT_COMPLETED receiver. It launches after storage is unlocked.</string>
    <string name="triggers_boot_explanation_locked">The app starts before the lock screen appears (LOCKED_BOOT_COMPLETED) — at a very early boot stage, before PIN/password entry.</string>
    <string name="triggers_boot_explanation_both">The app starts twice on boot: immediately after the system starts (LOCKED_BOOT) and again after storage is unlocked (BOOT_COMPLETED).</string>

    <!-- App Standby Bucket -->
    <string name="triggers_bucket_active_explanation">The app is in the ACTIVE bucket — the system applies no background restrictions. If you haven\'t used it recently, this is suspicious: something is keeping it active.</string>
    <string name="triggers_bucket_working_set_explanation">WORKING_SET bucket — the app is used frequently or the system considers it important. Restrictions are minimal; jobs and alarms run on schedule.</string>
    <string name="triggers_bucket_frequent_explanation">FREQUENT bucket — the app is used regularly. Some restrictions on rare background operations apply.</string>
    <string name="triggers_bucket_rare_explanation">RARE or RESTRICTED bucket — the system has limited this app\'s background activity. Jobs and alarms are heavily delayed or blocked.</string>

