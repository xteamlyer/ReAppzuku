<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <EditText
        android:id="@+id/filter_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/main_search_hint"
        android:inputType="text"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/search_background"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/filter_options_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/filter_btn_sort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/colorAccent"
            android:textStyle="bold"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:foreground="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/filter_btn_selectall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_select_all"
            android:textColor="@color/colorAccent"
            android:textStyle="bold"
            android:padding="8dp"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:visibility="gone" />

        <TextView
            android:id="@+id/filter_btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_clear"
            android:textColor="@color/colorAccent"
            android:textStyle="bold"
            android:padding="8dp"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/filter_loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible" />

    <ListView
        android:id="@+id/filter_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</LinearLayout>
