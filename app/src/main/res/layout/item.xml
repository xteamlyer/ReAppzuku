<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Material3.CardView.Filled"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="3dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:descendantFocusability="blocksDescendants">

    <LinearLayout
        android:id="@+id/linear1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="54dp"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/app_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"
            android:focusable="false"
            tools:src="@android:drawable/sym_def_app_icon" />

        <LinearLayout
            android:id="@+id/linear2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:focusable="false"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/protected_icon"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constrainedWidth="true" />

                <ImageView
                    android:id="@+id/protected_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_protected"
                    android:visibility="gone"
                    android:focusable="false"
                    app:layout_constraintStart_toEndOf="@id/app_name"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/whitelist_icon"
                    app:layout_goneMarginStart="0dp" />

                <ImageView
                    android:id="@+id/whitelist_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_whitelist"
                    android:visibility="gone"
                    android:focusable="false"
                    app:layout_constraintStart_toEndOf="@id/protected_icon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_goneMarginStart="0dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/app_pkg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:focusable="false" />

            <!-- Строка 3: ОЗУ + CPU + бейджи -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/app_ram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:focusable="false" />

                <TextView
                    android:id="@+id/app_cpu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:focusable="false" />

                <!--
                    System badge: оригинальный цвет текста #1A5276 (тёмно-синий).
                    Фон — полупрозрачный синий, хорошо виден и в светлой, и в тёмной теме.
                -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/badge_system"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginStart="6dp"
                    android:text="System"
                    android:textColor="#1A5276"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:focusable="false"
                    app:chipBackgroundColor="#2A1A5276"
                    app:chipStrokeColor="#1A5276"
                    app:chipStrokeWidth="1dp"
                    app:chipMinHeight="20dp"
                    app:chipStartPadding="6dp"
                    app:chipEndPadding="6dp"
                    app:ensureMinTouchTargetSize="false" />

                <!--
                    Persistent badge: оригинальный цвет текста #6C3483 (фиолетовый).
                -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/badge_persistent"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp"
                    android:text="Persistent"
                    android:textColor="#6C3483"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:focusable="false"
                    app:chipBackgroundColor="#2A6C3483"
                    app:chipStrokeColor="#6C3483"
                    app:chipStrokeWidth="1dp"
                    app:chipMinHeight="20dp"
                    app:chipStartPadding="6dp"
                    app:chipEndPadding="6dp"
                    app:ensureMinTouchTargetSize="false" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear_overflow"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:id="@+id/btn_overflow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear3"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="10dp">

            <ImageView
                android:id="@+id/btn_app_action"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_force_stop"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="false" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
