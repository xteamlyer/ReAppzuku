<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_scheduler_list.xml
    Главный диалог Restrictions Scheduler — прокручиваемый список приложений.
    Строки приложений добавляются программно через item_scheduler_app.xml.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/scheduler_list_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

</ScrollView>
