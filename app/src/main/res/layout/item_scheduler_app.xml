<?xml version="1.0" encoding="utf-8"?>
<!--
    item_scheduler_app.xml
    Строка приложения в диалоге Restrictions Scheduler.
    Левая часть: иконка + имя приложения.
    Правая часть: ic_scheduler + временной диапазон (скрыты если расписания нет).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Иконка приложения -->
    <ImageView
        android:id="@+id/scheduler_app_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:contentDescription="@null" />

    <!-- Имя приложения -->
    <TextView
        android:id="@+id/scheduler_app_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBody1" />

    <!-- Правый блок: иконка расписания + время -->
    <ImageView
        android:id="@+id/scheduler_entry_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="4dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_scheduler"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/scheduler_entry_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceCaption"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="invisible" />

</LinearLayout>
